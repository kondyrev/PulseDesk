generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String

  firstName String?
  lastName  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships     WorkspaceMember[]
  assignedTickets Ticket[]          @relation("AssignedTickets")
  readStates      TicketReadState[]
  sessions        Session[]
  partnerEvents   PartnerEvent[]

  @@map("users")
}

model Session {
  id String @id @default(uuid())

  token String @unique

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime

  createdAt DateTime @default(now())

  @@map("sessions")
}

model Workspace {
  id   String @id @default(uuid())
  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members                WorkspaceMember[]
  tickets                Ticket[]
  widgetSetting          WidgetSetting?
  qrCodes                QrCode[]
  partnerRecommendations PartnerRecommendation[]
  partnerEvents          PartnerEvent[]

  @@map("workspaces")
}

model WorkspaceMember {
  id String @id @default(uuid())

  workspaceId String
  userId      String

  role WorkspaceRole

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

enum WorkspaceRole {
  owner
  admin
  operator
}

model Ticket {
  id String @id @default(uuid())

  workspaceId String

  title String

  customerName  String?
  customerEmail String?

  status   TicketStatus   @default(new)
  priority TicketPriority @default(normal)
  source   TicketSource   @default(widget)

  assignedToId String?
  assignedTo   User?     @relation("AssignedTickets", fields: [assignedToId], references: [id])
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  messages   TicketMessage[]
  readStates TicketReadState[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tickets")
}

enum TicketStatus {
  new
  open
  waiting_customer
  waiting_operator
  resolved
  closed
}

enum TicketPriority {
  low
  normal
  high
  urgent
}

enum TicketSource {
  widget
  qr
  email
  manual
}

model TicketMessage {
  id String @id @default(uuid())

  ticketId String

  senderType MessageSender

  content String
  pageUrl String?

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("ticket_messages")
}

model TicketReadState {
  id String @id @default(uuid())

  ticketId String
  userId   String

  lastReadAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ticketId, userId])
  @@map("ticket_read_states")
}

enum MessageSender {
  customer
  operator
  system
}

model WidgetSetting {
  id String @id @default(uuid())

  workspaceId String @unique

  publicWidgetKey String  @unique
  isEnabled       Boolean @default(true)

  companyName String?
  title       String  @default("Поддержка")
  subtitle    String  @default("Обычно отвечаем в течение нескольких минут")

  primaryColor String         @default("#000000")
  position     WidgetPosition @default(bottom_right)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("widget_settings")
}

enum WidgetPosition {
  bottom_right
  bottom_left
}

model QrCode {
  id String @id @default(uuid())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  publicKey String @unique

  title       String  @default("Основной QR-код")
  description String?

  isPrimary Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("qr_codes")
}

model PartnerCategory {
  id String @id @default(uuid())

  code        String  @unique
  name        String
  description String?

  isActive Boolean @default(true)

  partners  Partner[]
  campaigns PartnerCampaign[]
  intents   Intent[]
  events    PartnerEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("partner_categories")
}

model Partner {
  id String @id @default(uuid())

  categoryId String?
  category   PartnerCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  name        String
  description String?
  websiteUrl  String?
  logoUrl     String?

  isActive Boolean @default(true)

  campaigns PartnerCampaign[]
  events    PartnerEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@map("partners")
}

model PartnerPlacement {
  id String @id @default(uuid())

  code        String  @unique
  name        String
  description String?

  isActive Boolean @default(true)

  campaigns PartnerCampaign[]
  events    PartnerEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("partner_placements")
}

model Intent {
  id String @id @default(uuid())

  categoryId String?
  category   PartnerCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  code        String  @unique
  name        String
  description String?

  isActive Boolean @default(true)

  campaigns PartnerCampaign[]
  events    PartnerEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@map("intents")
}

model PartnerCampaign {
  id String @id @default(uuid())

  partnerId String
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  categoryId String?
  category   PartnerCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  placementId String?
  placement   PartnerPlacement? @relation(fields: [placementId], references: [id], onDelete: SetNull)

  intentId String?
  intent   Intent? @relation(fields: [intentId], references: [id], onDelete: SetNull)

  title       String
  description String?

  targetAudience String?

  startsAt DateTime?
  endsAt   DateTime?

  isActive Boolean @default(true)

  recommendations PartnerRecommendation[]
  events          PartnerEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partnerId])
  @@index([categoryId])
  @@index([placementId])
  @@index([intentId])
  @@map("partner_campaigns")
}

model PartnerRecommendation {
  id String @id @default(uuid())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  partnerCampaignId String
  partnerCampaign   PartnerCampaign @relation(fields: [partnerCampaignId], references: [id], onDelete: Cascade)

  status PartnerRecommendationStatus @default(shown)

  shownAt     DateTime  @default(now())
  clickedAt   DateTime?
  dismissedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([partnerCampaignId])
  @@map("partner_recommendations")
}

enum PartnerRecommendationStatus {
  shown
  clicked
  dismissed
}

model PartnerEvent {
  id String @id @default(uuid())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  partnerId String?
  partner   Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  campaignId String?
  campaign   PartnerCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  categoryId String?
  category   PartnerCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  placementId String?
  placement   PartnerPlacement? @relation(fields: [placementId], references: [id], onDelete: SetNull)

  intentId String?
  intent   Intent? @relation(fields: [intentId], references: [id], onDelete: SetNull)

  eventType PartnerEventType

  categoryCode  String?
  placementCode String?
  intentCode    String?

  source   String?
  metadata Json?

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([userId])
  @@index([partnerId])
  @@index([campaignId])
  @@index([categoryId])
  @@index([placementId])
  @@index([intentId])
  @@index([eventType])
  @@index([categoryCode])
  @@index([placementCode])
  @@index([intentCode])
  @@index([createdAt])
  @@map("partner_events")
}

enum PartnerEventType {
  intent_detected
  recommendation_shown
  recommendation_click
  lead_created
  conversion_reported
}